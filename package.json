{
  "name": "welfare-portal-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Indian Government Welfare Schemes Portal",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm install --production",
    "test": "jest --coverage",
    "deploy": "npm run build && npm run package",
    "package": "zip -r lambda-deployment.zip . -x 'node_modules/*' '*.git*'",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "@anthropic-ai/sdk": "^0.16.0",
    "aws-sdk": "^2.1400.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "rate-limiter-flexible": "^2.4.1",
    "winston": "^3.10.0",
    "joi": "^17.10.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.50.0",
    "prettier": "^3.0.2"
  },
  "engines": {
    "node": "18.x"
  },
  "author": "Your Team",
  "license": "MIT"
}
